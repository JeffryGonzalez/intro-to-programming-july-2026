    {
      "id": "kxmGsPNeVOIxcX05U-K1W",
      "type": "text",
      "x": 528,
      "y": 370,
      "width": 512.9396362304688,
      "height": 175,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
