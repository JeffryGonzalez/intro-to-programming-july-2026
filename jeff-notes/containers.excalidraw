    {
      "id": "Jo_bEq_9MUG5lpE_zFdG4",
      "type": "text",
      "x": 356.4599609375,
      "y": 3136,
      "width": 765.8395385742188,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "aw",
      "roundness": null,
      "seed": 1158788147,
      "version": 374,
      "versionNonce": 1146837149,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1784306473588,
      "link": null,
      "locked": false,
      "text": "Containers run on any Open Container Initiative Runtime.\n    - Docker, the company, invented all this, but they opened the specification.\n  \n\nonly runs on linux. (need a linux kernel)\nwindows you do this by enabling the windows subsystem for linux (WSL)\n    - you do not need a distribution, just the kernel.\n\nContainers vs. Container c",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Containers run on any Open Container Initiative Runtime.\n    - Docker, the company, invented all this, but they opened the specification.\n  \n\nonly runs on linux. (need a linux kernel)\nwindows you do this by enabling the windows subsystem for linux (WSL)\n    - you do not need a distribution, just the kernel.\n\nContainers vs. Container c",
      "autoResize": true,
      "lineHeight": 1.25
    },
