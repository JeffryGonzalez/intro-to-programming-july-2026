      "boundElements": null,
      "updated": 1783354557861,
      "link": null,
      "locked": false,
      "text": "This service owns the process of formatting names\nNo other application anywhere should format names.\nThat is Alton's job. He has it. Trust him.\nBecause it might change, etc.\n\n(Service owns data and the process around that data)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "This service owns the process of formatting names\nNo other application anywhere should format names.\nThat is Alton's job. He has it. Trust him.\nBecause it might change, etc.\n\n(Service owns data and the process around that data)",
      "autoResize": true,
      "lineHeight": 1.25
    },
