      "isDeleted": false,
      "boundElements": null,
      "updated": 1783354443224,
      "link": null,
      "locked": false,
      "text": "Compile errors are usually type errors, and we love them.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Compile errors are usually type errors, and we love them.\n",
