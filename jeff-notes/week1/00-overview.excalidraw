      "boundElements": null,
      "updated": 1783355217137,
      "link": null,
      "locked": false,
      "text": "\nIf you are releasing a service and it has a breaking change:\n    - You have to redeploy all of the fixed clients at the same time as your change. \n        = \"Distributed Monolith\"",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\nIf you are releasing a service and it has a breaking change:\n    - You have to redeploy all of the fixed clients at the same time as your change. \n        = \"Distributed Monolith\"",
      "autoResize": true,
      "lineHeight": 1.35
    }
