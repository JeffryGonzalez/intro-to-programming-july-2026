      "updated": 1783454481107,
      "link": null,
      "locked": false,
      "text": "Docker (the company that \"invented\" containers)\nhas a thing called \"Docker Compose\"\n    - a script that runs that says \"start up all these\ncontainers on my machine so I can do my work\"\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Docker (the company that \"invented\" containers)\nhas a thing called \"Docker Compose\"\n    - a script that runs that says \"start up all these\ncontainers on my machine so I can do my work\"\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "htyrwMcUWI8TWCIej7AU4",
      "type": "text",
