      "boundElements": null,
      "updated": 1783692636932,
      "link": null,
      "locked": false,
      "text": "\"Temporal Coupling\"\n    - keep the things that change together together,\n    - (which means if they have a different rate of change,\n       keep them separate)",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"Temporal Coupling\"\n    - keep the things that change together together,\n    - (which means if they have a different rate of change,\n       keep them separate)",
