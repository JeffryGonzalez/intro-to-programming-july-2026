      "seed": 1962638117,
      "version": 414,
      "versionNonce": 54587877,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783365663763,
      "link": null,
      "locked": false,
      "text": "\"Trunk Based\"\n    - every developer on the team pushes right to \"main\" or \"master\", or whatever. No branches, none of that stuff.\n\n- Any changes to packages requires approval, often by the entire team.\n    - a change to a package has to be in a pull request BY ITSELF, and everyone has to approve it.",
      "fontSize": 20,
      "fontFamily": 6,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"Trunk Based\"\n    - every developer on the team pushes right to \"main\" or \"master\", or whatever. No branches, none of that stuff.\n\n- Any changes to packages requires approval, often by the entire team.\n    - a change to a package has to be in a pull request BY ITSELF, and everyone has to approve it.",
      "autoResize": true,
      "lineHeight": 1.35
    }
  ],
