    },
    {
      "id": "ZzsKSlknAUvxCO2qPrD2K",
      "type": "text",
      "x": 370,
      "y": 806,
      "width": 1177,
      "height": 500,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "af",
      "roundness": null,
      "seed": 416235229,
      "version": 846,
      "versionNonce": 780097267,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783533946564,
      "link": null,
      "locked": false,
      "text": "The sequence of the increments is planned by the team to deliver value and prove direction.\n\nYAGNI as much as possible. (You Ain't Going to Need It) JFHCI\n\nDo the scary stuff up front. (sneakily a thing they do sometimes with new programmers here at your company)\n\nMost of the effort in each iteration is \"design\" for that iteration, the rest is coding it.\n- Figure out *what* you are building before you make it good.\n\n\nAll code must:\n\n- Work. If it doesn't nothing else matters.\n    - passes tests\n- Try to make your code (and tests) convey what it \"means\", what knowledge lives here?\n    - reveals intention\n- Minimize duplication of nameable \"things\"\n    - minimize duplication\n- Write as little as possible to get the job done\n    - fewest number of elements",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "The sequence of the increments is planned by the team to deliver value and prove direction.\n\nYAGNI as much as possible. (You Ain't Going to Need It) JFHCI\n\nDo the scary stuff up front. (sneakily a thing they do sometimes with new programmers here at your company)\n\nMost of the effort in each iteration is \"design\" for that iteration, the rest is coding it.\n- Figure out *what* you are building before you make it good.\n\n\nAll code must:\n\n- Work. If it doesn't nothing else matters.\n    - passes tests\n- Try to make your code (and tests) convey what it \"means\", what knowledge lives here?\n    - reveals intention\n- Minimize duplication of nameable \"things\"\n    - minimize duplication\n- Write as little as possible to get the job done\n    - fewest number of elements",
      "autoResize": true,
      "lineHeight": 1.25
    },
