    {
      "id": "BOUl9hHrHYJVj-fdC3BdJ",
      "type": "text",
      "x": -50,
      "y": 975,
      "width": 421.0396728515625,
      "height": 300,
      "angle": 0,
      "strokeColor": "#1e1e1e",
