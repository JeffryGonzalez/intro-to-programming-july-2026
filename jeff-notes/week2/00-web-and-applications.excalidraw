      "seed": 1312724403,
      "version": 349,
      "versionNonce": 2029043123,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1783954260011,
      "link": null,
      "locked": false,
      "text": "JWT - \nThese can be captured\nby a mitm attack.\nDevelopers do dumb things\nlike save them in local storage\nbasically pretty scary insecure.\nSuper easy to write code to\nautomatically add the JWT\nto an authorization header\nfor any outgoing request,\nbut that token SHOULDN'T \nbe sent to APIs that it isn't intended for.",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "JWT - \nThese can be captured\nby a mitm attack.\nDevelopers do dumb things\nlike save them in local storage\nbasically pretty scary insecure.\nSuper easy to write code to\nautomatically add the JWT\nto an authorization header\nfor any outgoing request,\nbut that token SHOULDN'T \nbe sent to APIs that it isn't intended for.",
      "autoResize": true,
      "lineHeight": 1.25
    },
