      "link": null,
      "locked": false,
      "text": "AngularJS \n(emberjs, blueprint mvc)\n\nHTTP is stateless messaging passing.\nApplications have to have state. (State is basically \"data + user + time\")",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "AngularJS \n(emberjs, blueprint mvc)\n\nHTTP is stateless messaging passing.\nApplications have to have state. (State is basically \"data + user + time\")",
      "autoResize": true,
      "lineHeight": 1.25
    },
