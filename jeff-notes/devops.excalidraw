    {
      "id": "Ukh4nFNwHXuqtlXokuOyH",
      "type": "text",
      "x": -159,
      "y": 798,
      "width": 465.5596923828125,
      "height": 350,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "dotted",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0G",
      "roundness": null,
      "seed": 1206014575,
      "version": 327,
      "versionNonce": 200924641,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1784302142456,
      "link": null,
      "locked": false,
      "text": "emergent design\nnovel\ncreating something new\n\nas absolutely little testing\nas is needed. Really.\nBe frugal, but real.\n\nAnd that's because a lot of the code you write\nis going to be changed, deleted, replaced, etc.\n\nplaywright - record tests, make sure you \ndon't have regressions.\n",
      "fontSize": 20,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "emergent design\nnovel\ncreating something new\n\nas absolutely little testing\nas is needed. Really.\nBe frugal, but real.\n\nAnd that's because a lot of the code you write\nis going to be changed, deleted, replaced, etc.\n\nplaywright - record tests, make sure you \ndon't have regressions.\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
