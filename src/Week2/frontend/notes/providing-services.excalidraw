      "updated": 1784056608869,
      "link": null,
      "locked": false,
      "text": "\"Blue - created for each request and shared only within that request.\nThey are disposed of at the end of the request These are \"Scoped\" services\".\n\nRed things are \"singletons\" - they stay around as long as your API is\nrunning.\n\n",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "\"Blue - created for each request and shared only within that request.\nThey are disposed of at the end of the request These are \"Scoped\" services\".\n\nRed things are \"singletons\" - they stay around as long as your API is\nrunning.\n\n",
      "autoResize": true,
      "lineHeight": 1.25
    },
