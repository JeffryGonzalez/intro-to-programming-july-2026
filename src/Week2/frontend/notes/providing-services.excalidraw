      "boundElements": null,
      "updated": 1784054716428,
      "link": null,
      "locked": false,
      "text": "In Angular, once a service is provided* it will stay in memory \"forever\"**",
      "fontSize": 20,
      "fontFamily": 8,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "In Angular, once a service is provided* it will stay in memory \"forever\"**",
      "autoResize": true,
      "lineHeight": 1.25
    },
