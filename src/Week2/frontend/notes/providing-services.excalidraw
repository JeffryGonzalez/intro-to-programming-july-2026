    {
      "id": "5b8UxrTHramonp7D48WGV",
      "type": "text",
      "x": 170,
      "y": 73,
      "width": 814,
      "height": 25,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
